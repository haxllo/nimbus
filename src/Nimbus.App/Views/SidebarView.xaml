<UserControl
    x:Class="Nimbus.App.Views.SidebarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Nimbus.App.Views">
    <UserControl.Resources>
        <SolidColorBrush x:Key="SidebarPanelBrush" Color="#EEF0F4" />
        <SolidColorBrush x:Key="SidebarDividerBrush" Color="#D2D2D8" />
        <SolidColorBrush x:Key="SidebarMutedBrush" Color="#66666D" />

        <Style x:Key="SidebarSectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource SidebarMutedBrush}" />
            <Setter Property="CharacterSpacing" Value="40" />
        </Style>

        <Style x:Key="SidebarListStyle" TargetType="ListView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="SelectionMode" Value="Single" />
        </Style>
    </UserControl.Resources>

    <Border Margin="0,0,0,0" Padding="8,8,8,4" Background="{StaticResource SidebarPanelBrush}" BorderBrush="{StaticResource SidebarDividerBrush}" BorderThickness="1" CornerRadius="10">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Favorites" Style="{StaticResource SidebarSectionHeaderStyle}" Margin="8,2,8,8" />
        <ListView
            x:Name="SidebarList"
            Grid.Row="1"
            Style="{StaticResource SidebarListStyle}"
            ItemsSource="{Binding Locations}"
            SelectionChanged="OnLocationSelectionChanged"
            Margin="0,0,0,12">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,5">
                        <TextBlock
                            Text="{Binding IconKey}"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="13"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SidebarMutedBrush}" />
                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBlock Grid.Row="2" Text="Smart Collections" Style="{StaticResource SidebarSectionHeaderStyle}" Margin="8,0,8,8" />
        <ListView
            x:Name="SavedSearchList"
            Grid.Row="3"
            Style="{StaticResource SidebarListStyle}"
            ItemsSource="{Binding SavedSearches}"
            SelectionChanged="OnSavedSearchSelectionChanged"
            Margin="0,0,0,12"
            MaxHeight="140">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,5">
                        <TextBlock
                            Text="{Binding IconGlyph}"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="13"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SidebarMutedBrush}" />
                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBlock Grid.Row="4" Text="Tags" Style="{StaticResource SidebarSectionHeaderStyle}" Margin="8,0,8,8" />
        <ListView
            x:Name="TagsList"
            Grid.Row="5"
            Style="{StaticResource SidebarListStyle}"
            ItemsSource="{Binding Tags}"
            SelectionChanged="OnTagSelectionChanged"
            MaxHeight="140">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,5">
                        <TextBlock
                            Text="{Binding IconGlyph}"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="13"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SidebarMutedBrush}" />
                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
    </Border>
</UserControl>
