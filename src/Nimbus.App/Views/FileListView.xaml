<UserControl
    x:Class="Nimbus.App.Views.FileListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Nimbus.App.Views">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="ListItemsPanel">
            <ItemsStackPanel />
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="GridItemsPanel">
            <ItemsWrapGrid Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <DataTemplate x:Key="ListModeTemplate">
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,4">
                <Grid Width="24" Height="24">
                    <TextBlock
                        Text="{Binding IconGlyph}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                    <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill" />
                </Grid>
                <TextBlock Text="{Binding DisplayName}" Width="248" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding DateModified}" Width="160" />
                <TextBlock Text="{Binding SizeBytes}" Width="120" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="IconModeTemplate">
            <StackPanel Width="140" Height="120" Margin="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Height="72" CornerRadius="6">
                    <Grid>
                        <TextBlock
                            Text="{Binding IconGlyph}"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0.85" />
                        <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill" />
                    </Grid>
                </Border>
                <TextBlock Text="{Binding DisplayName}" Margin="0,8,0,0" TextAlignment="Center" TextWrapping="WrapWholeWords" MaxLines="2" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ColumnModeTemplate">
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,4">
                <Grid Width="24" Height="24">
                    <TextBlock
                        Text="{Binding IconGlyph}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                    <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill" />
                </Grid>
                <StackPanel Width="280">
                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Text="{Binding DateModified}" Width="160" />
                <TextBlock Text="{Binding SizeBytes}" Width="120" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="GalleryModeTemplate">
            <Border Width="220" Height="180" Margin="10" Padding="12" CornerRadius="8">
                <StackPanel Spacing="8">
                    <Border Height="90" CornerRadius="6">
                        <Grid>
                            <TextBlock
                                Text="{Binding IconGlyph}"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="32"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.85" />
                            <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill" />
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding DateModified}" FontSize="11" Opacity="0.8" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid x:Name="ListHeaderGrid" ColumnSpacing="12" Padding="16,8,16,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Name" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="Date Modified" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" Text="Size" FontWeight="SemiBold" />
        </Grid>
        <ListView
            x:Name="FileList"
            Grid.Row="1"
            ItemsSource="{Binding Items}"
            ItemsPanel="{StaticResource ListItemsPanel}"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
            SelectionChanged="OnSelectionChanged"
            DoubleTapped="OnDoubleTapped" />
    </Grid>
</UserControl>
