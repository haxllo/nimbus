<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="Nimbus.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Nimbus.App"
    xmlns:views="using:Nimbus.App.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Left" Modifiers="Menu" Invoked="OnBackAcceleratorInvoked" />
        <KeyboardAccelerator Key="Right" Modifiers="Menu" Invoked="OnForwardAcceleratorInvoked" />
        <KeyboardAccelerator Key="F5" Invoked="OnRefreshAcceleratorInvoked" />
        <KeyboardAccelerator Key="Delete" Invoked="OnDeleteAcceleratorInvoked" />
        <KeyboardAccelerator Key="F2" Invoked="OnRenameAcceleratorInvoked" />
        <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="OnSearchFocusAcceleratorInvoked" />
    </Page.KeyboardAccelerators>
    <Page.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Padding="12" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton" Content="Back" Click="OnBackClicked" />
                <Button x:Name="ForwardButton" Grid.Column="1" Content="Forward" Click="OnForwardClicked" Margin="8,0,0,0" />
                <Button x:Name="RefreshButton" Grid.Column="2" Content="Refresh" Click="OnRefreshClicked" Margin="8,0,0,0" />
                <Button x:Name="NewFolderButton" Grid.Column="3" Content="New Folder" Click="OnNewFolderClicked" Margin="8,0,0,0" />
                <Button x:Name="RenameButton" Grid.Column="4" Content="Rename" Click="OnRenameClicked" Margin="8,0,0,0" />
                <Button x:Name="DeleteButton" Grid.Column="5" Content="Delete" Click="OnDeleteClicked" Margin="8,0,0,0" />
                <TextBox x:Name="PathBox" Grid.Column="6" Margin="12,0,12,0" PlaceholderText="Path" KeyDown="OnPathBoxKeyDown" />
                <TextBox x:Name="SearchBox" Grid.Column="7" PlaceholderText="Search" KeyDown="OnSearchBoxKeyDown" />
            </Grid>

            <ScrollViewer Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal" Spacing="4" Padding="12,4,12,8" />
            </ScrollViewer>

            <views:SidebarView x:Name="Sidebar" Grid.Row="2" Grid.Column="0" DataContext="{Binding Sidebar}" />
            <views:FileListView x:Name="FileList" Grid.Row="2" Grid.Column="1" DataContext="{Binding FileList}" />
            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Padding="12,8">
                <TextBlock x:Name="StatusTextBlock" Text="Ready." TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Page.Content>
</Page>
