<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="Nimbus.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Nimbus.App"
    xmlns:views="using:Nimbus.App.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Left" Modifiers="Menu" Invoked="OnBackAcceleratorInvoked" />
        <KeyboardAccelerator Key="Right" Modifiers="Menu" Invoked="OnForwardAcceleratorInvoked" />
        <KeyboardAccelerator Key="F5" Invoked="OnRefreshAcceleratorInvoked" />
        <KeyboardAccelerator Key="N" Modifiers="Control" Invoked="OnNewFolderAcceleratorInvoked" />
        <KeyboardAccelerator Key="Delete" Invoked="OnDeleteAcceleratorInvoked" />
        <KeyboardAccelerator Key="F2" Invoked="OnRenameAcceleratorInvoked" />
        <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="OnSearchFocusAcceleratorInvoked" />
        <KeyboardAccelerator Key="T" Modifiers="Control" Invoked="OnNewTabAcceleratorInvoked" />
        <KeyboardAccelerator Key="W" Modifiers="Control" Invoked="OnCloseTabAcceleratorInvoked" />
        <KeyboardAccelerator Key="Tab" Modifiers="Control" Invoked="OnNextTabAcceleratorInvoked" />
        <KeyboardAccelerator Key="Tab" Modifiers="Control,Shift" Invoked="OnPreviousTabAcceleratorInvoked" />
        <KeyboardAccelerator Key="Space" Invoked="OnQuickLookAcceleratorInvoked" />
    </Page.KeyboardAccelerators>
    <Page.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <TabView
                x:Name="TabsControl"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="8,8,8,0"
                CanCloseTabs="True"
                IsAddTabButtonVisible="True"
                TabItemsSource="{Binding Tabs.Tabs}"
                AddTabButtonClick="OnAddTabButtonClick"
                TabCloseRequested="OnTabCloseRequested"
                SelectionChanged="OnTabSelectionChanged">
                <TabView.TabItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </TabView.TabItemTemplate>
            </TabView>

            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Padding="12" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton" Content="Back" Click="OnBackClicked" ToolTipService.ToolTip="Back (Alt+Left)" />
                <Button x:Name="ForwardButton" Grid.Column="1" Content="Forward" Click="OnForwardClicked" Margin="8,0,0,0" ToolTipService.ToolTip="Forward (Alt+Right)" />
                <Button x:Name="RefreshButton" Grid.Column="2" Content="Refresh" Click="OnRefreshClicked" Margin="8,0,0,0" ToolTipService.ToolTip="Refresh (F5)" />
                <Button x:Name="NewFolderButton" Grid.Column="3" Content="New Folder" Click="OnNewFolderClicked" Margin="8,0,0,0" ToolTipService.ToolTip="New Folder (Ctrl+N)" />
                <Button x:Name="RenameButton" Grid.Column="4" Content="Rename" Click="OnRenameClicked" Margin="8,0,0,0" ToolTipService.ToolTip="Rename (F2)" />
                <Button x:Name="DeleteButton" Grid.Column="5" Content="Delete" Click="OnDeleteClicked" Margin="8,0,0,0" ToolTipService.ToolTip="Delete (Delete)" />
                <ComboBox x:Name="ViewModeSelector" Grid.Column="6" Margin="12,0,0,0" SelectionChanged="OnViewModeSelectionChanged" ToolTipService.ToolTip="View mode (Finder-style)">
                    <x:String>List</x:String>
                    <x:String>Icon</x:String>
                    <x:String>Column</x:String>
                    <x:String>Gallery</x:String>
                </ComboBox>
                <ComboBox x:Name="SortSelector" Grid.Column="7" SelectedIndex="0" ToolTipService.ToolTip="Sort order">
                    <x:String>Name</x:String>
                    <x:String>Date Modified</x:String>
                    <x:String>Size</x:String>
                </ComboBox>
                <TextBox x:Name="PathBox" Grid.Column="8" Margin="12,0,12,0" PlaceholderText="Path" KeyDown="OnPathBoxKeyDown" />
                <TextBox x:Name="SearchBox" Grid.Column="9" PlaceholderText="Search" KeyDown="OnSearchBoxKeyDown" ToolTipService.ToolTip="Search (Ctrl+F)" />
            </Grid>

            <ScrollViewer Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal" Spacing="4" Padding="12,4,12,8" />
            </ScrollViewer>

            <views:SidebarView x:Name="Sidebar" Grid.Row="3" Grid.Column="0" DataContext="{Binding Sidebar}" />
            <views:FileListView x:Name="FileList" Grid.Row="3" Grid.Column="1" DataContext="{Binding FileList}" />
            <Border Grid.Row="3" Grid.Column="2" Margin="8,0,12,0" Padding="12" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Preview" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Name" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.Name}" />
                    <TextBlock Text="Path" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.Path}" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="Type" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.ItemType}" />
                    <TextBlock Text="Modified" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.DateModified}" />
                    <TextBlock Text="Size (bytes)" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.SizeBytes}" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.ErrorMessage}" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.ImagePath}" TextWrapping="WrapWholeWords" />
                    <TextBox
                        Text="{Binding FileList.CurrentPreview.TextPreview, Mode=OneWay}"
                        IsReadOnly="True"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        Height="180" />
                    <Border Margin="0,12,0,0" Padding="8" CornerRadius="6">
                        <TextBlock Text="Press Space for Quick Look." TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>
            </Border>
            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Padding="12,8">
                <InfoBar
                    x:Name="StatusInfoBar"
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Informational"
                    Message="Ready." />
            </Border>
        </Grid>
    </Page.Content>
</Page>
