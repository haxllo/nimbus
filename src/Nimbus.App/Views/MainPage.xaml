<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="Nimbus.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Nimbus.App"
    xmlns:views="using:Nimbus.App.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <SolidColorBrush x:Key="FinderWindowBrush" Color="#F3F3F5" />
        <SolidColorBrush x:Key="FinderChromeBrush" Color="#ECECF0" />
        <SolidColorBrush x:Key="FinderPanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="FinderDividerBrush" Color="#D2D2D8" />
        <SolidColorBrush x:Key="FinderSubtleTextBrush" Color="#5E5E65" />
        <SolidColorBrush x:Key="FinderTabBrush" Color="#E4E4EA" />
        <SolidColorBrush x:Key="FinderTabActiveBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="FinderBlueBrush" Color="#0A84FF" />

        <Style x:Key="FinderToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource FinderDividerBrush}" />
            <Setter Property="Background" Value="{StaticResource FinderPanelBrush}" />
        </Style>

        <Style x:Key="FinderNavButtonStyle" TargetType="Button" BasedOn="{StaticResource FinderToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="FinderTabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource FinderDividerBrush}" />
            <Setter Property="Background" Value="{StaticResource FinderTabBrush}" />
        </Style>

        <Style x:Key="FinderTabButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource FinderTabButtonStyle}">
            <Setter Property="Background" Value="{StaticResource FinderTabActiveBrush}" />
            <Setter Property="Foreground" Value="{StaticResource FinderBlueBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FinderBlueBrush}" />
        </Style>

        <Style x:Key="FinderBreadcrumbButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource FinderSubtleTextBrush}" />
        </Style>
    </Page.Resources>
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Left" Modifiers="Menu" Invoked="OnBackAcceleratorInvoked" />
        <KeyboardAccelerator Key="Right" Modifiers="Menu" Invoked="OnForwardAcceleratorInvoked" />
        <KeyboardAccelerator Key="F5" Invoked="OnRefreshAcceleratorInvoked" />
        <KeyboardAccelerator Key="N" Modifiers="Control" Invoked="OnNewFolderAcceleratorInvoked" />
        <KeyboardAccelerator Key="Delete" Invoked="OnDeleteAcceleratorInvoked" />
        <KeyboardAccelerator Key="F2" Invoked="OnRenameAcceleratorInvoked" />
        <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="OnSearchFocusAcceleratorInvoked" />
        <KeyboardAccelerator Key="T" Modifiers="Control" Invoked="OnNewTabAcceleratorInvoked" />
        <KeyboardAccelerator Key="W" Modifiers="Control" Invoked="OnCloseTabAcceleratorInvoked" />
        <KeyboardAccelerator Key="Tab" Modifiers="Control" Invoked="OnNextTabAcceleratorInvoked" />
        <KeyboardAccelerator Key="Tab" Modifiers="Control,Shift" Invoked="OnPreviousTabAcceleratorInvoked" />
        <KeyboardAccelerator Key="Space" Invoked="OnQuickLookAcceleratorInvoked" />
    </Page.KeyboardAccelerators>
    <Page.Content>
        <Grid Background="{StaticResource FinderWindowBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="260" MinWidth="180" MaxWidth="520" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition x:Name="PreviewColumn" Width="300" MinWidth="220" MaxWidth="620" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5" Margin="12,10,12,6" Padding="10,8" Background="{StaticResource FinderChromeBrush}" BorderBrush="{StaticResource FinderDividerBrush}" BorderThickness="1" CornerRadius="12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="230" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse Width="11" Height="11" Fill="#FF5F57" />
                        <Ellipse Width="11" Height="11" Fill="#FEBC2E" />
                        <Ellipse Width="11" Height="11" Fill="#28C840" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,2,0">
                        <TextBlock Text="Nimbus" FontWeight="SemiBold" />
                        <TextBlock Text="  Finder View" Foreground="{StaticResource FinderSubtleTextBrush}" />
                    </StackPanel>

                    <Button x:Name="BackButton" Grid.Column="2" Click="OnBackClicked" ToolTipService.ToolTip="Back (Alt+Left)" Style="{StaticResource FinderNavButtonStyle}">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button x:Name="ForwardButton" Grid.Column="3" Click="OnForwardClicked" ToolTipService.ToolTip="Forward (Alt+Right)" Style="{StaticResource FinderNavButtonStyle}">
                        <FontIcon Glyph="&#xE72A;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button x:Name="RefreshButton" Grid.Column="4" Click="OnRefreshClicked" ToolTipService.ToolTip="Refresh (F5)" Style="{StaticResource FinderNavButtonStyle}">
                        <FontIcon Glyph="&#xE72C;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button x:Name="NewFolderButton" Grid.Column="5" Content="New Folder" Click="OnNewFolderClicked" ToolTipService.ToolTip="New Folder (Ctrl+N)" Style="{StaticResource FinderToolbarButtonStyle}" />
                    <Button x:Name="RenameButton" Grid.Column="6" Content="Rename" Click="OnRenameClicked" ToolTipService.ToolTip="Rename (F2)" Style="{StaticResource FinderToolbarButtonStyle}" />
                    <Button x:Name="DeleteButton" Grid.Column="7" Content="Delete" Click="OnDeleteClicked" ToolTipService.ToolTip="Delete (Delete)" Style="{StaticResource FinderToolbarButtonStyle}" />
                    <ComboBox x:Name="ViewModeSelector" Grid.Column="8" SelectionChanged="OnViewModeSelectionChanged" ToolTipService.ToolTip="View mode (Finder-style)">
                        <x:String>List</x:String>
                        <x:String>Icon</x:String>
                        <x:String>Column</x:String>
                        <x:String>Gallery</x:String>
                    </ComboBox>
                    <ComboBox x:Name="SortSelector" Grid.Column="9" SelectionChanged="OnSortSelectionChanged" ToolTipService.ToolTip="Sort order">
                        <x:String>Name (A-Z)</x:String>
                        <x:String>Name (Z-A)</x:String>
                        <x:String>Date Modified (Oldest)</x:String>
                        <x:String>Date Modified (Newest)</x:String>
                        <x:String>Size (Smallest)</x:String>
                        <x:String>Size (Largest)</x:String>
                    </ComboBox>
                    <TextBox x:Name="PathBox" Grid.Column="10" Margin="8,0,8,0" PlaceholderText="Path" KeyDown="OnPathBoxKeyDown" />
                    <TextBox x:Name="SearchBox" Grid.Column="11" PlaceholderText="Search in current folder" KeyDown="OnSearchBoxKeyDown" ToolTipService.ToolTip="Search (Ctrl+F)" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Margin="12,0,12,4" Padding="8,6" Background="{StaticResource FinderChromeBrush}" BorderBrush="{StaticResource FinderDividerBrush}" BorderThickness="1" CornerRadius="10">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                        <StackPanel x:Name="TabStripPanel" Orientation="Horizontal" Spacing="6" />
                    </ScrollViewer>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <Button x:Name="NewTabButton" Content="+ Tab" Click="OnNewTabClicked" ToolTipService.ToolTip="New Tab (Ctrl+T)" Style="{StaticResource FinderToolbarButtonStyle}" />
                        <Button x:Name="CloseTabButton" Content="Close Tab" Click="OnCloseTabClicked" ToolTipService.ToolTip="Close Tab (Ctrl+W)" Style="{StaticResource FinderToolbarButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Margin="12,0,12,0" HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal" Spacing="4" Padding="12,4,12,8" />
            </ScrollViewer>

            <views:SidebarView x:Name="Sidebar" Grid.Row="3" Grid.Column="0" DataContext="{Binding Sidebar}" />
            <Border
                x:Name="SidebarSplitter"
                Grid.Row="3"
                Grid.Column="1"
                Width="6"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{StaticResource FinderDividerBrush}"
                PointerPressed="OnSidebarSplitterPointerPressed"
                PointerMoved="OnSidebarSplitterPointerMoved"
                PointerReleased="OnSidebarSplitterPointerReleased"
                PointerCanceled="OnSidebarSplitterPointerCanceled" />
            <views:FileListView x:Name="FileList" Grid.Row="3" Grid.Column="2" DataContext="{Binding FileList}" />
            <Border
                x:Name="PreviewSplitter"
                Grid.Row="3"
                Grid.Column="3"
                Width="6"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{StaticResource FinderDividerBrush}"
                PointerPressed="OnPreviewSplitterPointerPressed"
                PointerMoved="OnPreviewSplitterPointerMoved"
                PointerReleased="OnPreviewSplitterPointerReleased"
                PointerCanceled="OnPreviewSplitterPointerCanceled" />
            <Border Grid.Row="3" Grid.Column="4" Margin="8,0,12,0" Padding="12" Background="{StaticResource FinderPanelBrush}" BorderBrush="{StaticResource FinderDividerBrush}" BorderThickness="1" CornerRadius="10">
                <StackPanel Spacing="8">
                    <TextBlock Text="Preview" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Name" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.Name}" />
                    <TextBlock Text="Path" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.Path}" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="Type" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.ItemType}" />
                    <TextBlock Text="Modified" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.DateModified}" />
                    <TextBlock Text="Size (bytes)" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.SizeBytes}" />
                    <TextBlock Text="Status" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.ErrorMessage}" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="Text Preview" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.CurrentPreview.TextPreview}" TextWrapping="WrapWholeWords" MaxLines="14" />
                    <Border Margin="0,12,0,0" Padding="8" CornerRadius="6">
                        <TextBlock Text="Press Space for Quick Look." TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>
            </Border>
            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5" Margin="12,6,12,10" Padding="12,8" Background="{StaticResource FinderPanelBrush}" BorderBrush="{StaticResource FinderDividerBrush}" BorderThickness="1" CornerRadius="10">
                <InfoBar
                    x:Name="StatusInfoBar"
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Informational"
                    Message="Ready." />
            </Border>
        </Grid>
    </Page.Content>
</Page>
