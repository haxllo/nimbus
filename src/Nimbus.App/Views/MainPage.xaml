<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="Nimbus.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Nimbus.App"
    xmlns:views="using:Nimbus.App.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Padding="12" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton" Content="Back" Click="OnBackClicked" />
                <Button x:Name="ForwardButton" Grid.Column="1" Content="Forward" Click="OnForwardClicked" Margin="8,0,0,0" />
                <TextBox x:Name="PathBox" Grid.Column="2" Margin="12,0,12,0" PlaceholderText="Path" KeyDown="OnPathBoxKeyDown" />
                <TextBox x:Name="SearchBox" Grid.Column="3" PlaceholderText="Search" KeyDown="OnSearchBoxKeyDown" />
            </Grid>

            <views:SidebarView x:Name="Sidebar" Grid.Row="1" Grid.Column="0" DataContext="{Binding Sidebar}" />
            <views:FileListView x:Name="FileList" Grid.Row="1" Grid.Column="1" DataContext="{Binding FileList}" />
        </Grid>
    </Page.Content>
</Page>
